logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Local SQLite (Better-SQLite3 WAL files)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# User uploads & generated media on disk
backend/storage/

